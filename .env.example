# Copy to .env for local docker-compose runs. iam-core settings are optional;
# without them ztna-api boots in degraded mode (authenticated API returns 503).
IAM_CORE_ISSUER=
IAM_CORE_CLIENT_ID=
IAM_CORE_CLIENT_SECRET=
IAM_CORE_AUDIENCE=
# base64-encoded 32-byte AES-256 key (e.g. `openssl rand -base64 32`).
ACCESS_CREDENTIAL_DEK=
# Per-workspace key manager (preferred over ACCESS_CREDENTIAL_DEK when set):
# base64-encoded 32-byte master key from which a distinct DEK is derived per
# workspace (HKDF). Gives tenant key separation without an external KMS.
ACCESS_KMS_MASTER_KEY=
# Current key version new writes seal under; bump to rotate (old rows still
# open under the version recorded with them). Defaults to 1.
ACCESS_KMS_KEY_VERSION=1
# Per-tenant inbound rate limiting on the authenticated API, so one noisy or
# runaway tenant cannot monopolise the shared Postgres pool. In-memory and
# therefore per-replica: with N ztna-api replicas a tenant's effective ceiling
# is N x RPS. Enabled by default with generous limits; set ENABLED=false to turn
# it off. RPS is the sustained per-tenant rate, BURST the instantaneous bucket
# depth (a dashboard page load fans out into several XHRs, so BURST > RPS).
ACCESS_TENANT_RATE_LIMIT_ENABLED=true
ACCESS_TENANT_RATE_LIMIT_RPS=50
ACCESS_TENANT_RATE_LIMIT_BURST=100
# Shared store (Redis) for the control plane: the cross-replica backend for the
# rate limiter and usage accumulator below, plus the future worker queue. Leave
# empty for the default per-replica posture (no Redis dependency). When set, the
# SHARED_STORE flags below become honoured.
ACCESS_REDIS_URL=
# Make the rate limit GLOBALLY EXACT across replicas via an atomic Redis token
# bucket, so a tenant's ceiling is RPS fleet-wide instead of N x RPS. Only
# honoured when ACCESS_REDIS_URL is set (otherwise it falls back to the
# per-replica in-memory bucket and logs a warning). Fail-open: a Redis outage
# reverts to admitting requests, never rejecting them.
ACCESS_TENANT_RATE_LIMIT_SHARED_STORE=false
# Per-tenant usage metering: the "who is using what" half of the cost story.
# Every authenticated, tenant-scoped request increments an in-memory per-tenant
# counter; counts flush to the tenant_usage rollup so cost-to-serve is
# attributable per tenant (read back via GET /api/v1/usage). Per-tenant numbers
# live in Postgres, NOT Prometheus labels (5,000 tenants would explode the
# series count); only an aggregate counter reaches /metrics. In-memory and
# per-replica: each replica flushes its own deltas with an additive UPSERT, so
# replicas sum rather than overwrite. FLUSH_INTERVAL bounds both write volume
# and how stale the read endpoint is. Set ENABLED=false to turn it off.
ACCESS_USAGE_METERING_ENABLED=true
ACCESS_USAGE_METERING_FLUSH_INTERVAL=30s
# Per-tenant billing: the "what may a tenant consume, and what does it owe" half
# of the cost story, layered ON TOP of usage metering. It turns the tenant_usage
# rollup into periodized statements (GET /api/v1/billing/statement) and enforces
# per-tenant plan quotas — soft warnings over the included allowance, hard caps
# (HTTP 402) over the ceiling — via a fail-open middleware keyed by tenant. Plans
# reuse the tenancy tier ladder (trial/base/pro/enterprise); the quota ladders
# and integer pricing live in code. DISABLED by default: unlike metering it can
# reject requests, so it is opt-in. ENFORCE_HARD_CAP also defaults to false —
# the safe rollout is "shadow mode" (detect + surface breaches via headers and
# metrics, but still allow) so an operator can see who WOULD be capped before
# flipping enforcement on. The decision is cached per workspace for CACHE_TTL
# (per-replica, like the limiter), so enforcement adds no per-request DB read and
# the fleet converges within that window. Requires ACCESS_USAGE_METERING_ENABLED.
ACCESS_BILLING_ENABLED=false
ACCESS_BILLING_ENFORCE_HARD_CAP=false
ACCESS_BILLING_CACHE_TTL=30s
# Consolidate usage through the shared Redis accumulator: per-replica deltas sum
# into one Redis counter and a single claim-based flush rolls it up into
# tenant_usage, instead of every replica writing the same row each window.
# Postgres stays the durable record. Only honoured when ACCESS_REDIS_URL is set
# (otherwise it falls back to the per-replica additive UPSERT and logs a
# warning). Fail-open: a Redis outage degrades to the Postgres path or drops,
# never blocking a request.
ACCESS_USAGE_METERING_SHARED_STORE=false
