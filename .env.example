# Copy to .env for local docker-compose runs. iam-core settings are optional;
# without them ztna-api boots in degraded mode (authenticated API returns 503).
IAM_CORE_ISSUER=
IAM_CORE_CLIENT_ID=
IAM_CORE_CLIENT_SECRET=
IAM_CORE_AUDIENCE=
# base64-encoded 32-byte AES-256 key (e.g. `openssl rand -base64 32`).
ACCESS_CREDENTIAL_DEK=
# Per-workspace key manager (preferred over ACCESS_CREDENTIAL_DEK when set):
# base64-encoded 32-byte master key from which a distinct DEK is derived per
# workspace (HKDF). Gives tenant key separation without an external KMS.
ACCESS_KMS_MASTER_KEY=
# Current key version new writes seal under; bump to rotate (old rows still
# open under the version recorded with them). Defaults to 1.
ACCESS_KMS_KEY_VERSION=1
# Per-tenant inbound rate limiting on the authenticated API, so one noisy or
# runaway tenant cannot monopolise the shared Postgres pool. In-memory and
# therefore per-replica: with N ztna-api replicas a tenant's effective ceiling
# is N x RPS. Enabled by default with generous limits; set ENABLED=false to turn
# it off. RPS is the sustained per-tenant rate, BURST the instantaneous bucket
# depth (a dashboard page load fans out into several XHRs, so BURST > RPS).
ACCESS_TENANT_RATE_LIMIT_ENABLED=true
ACCESS_TENANT_RATE_LIMIT_RPS=50
ACCESS_TENANT_RATE_LIMIT_BURST=100
# Per-tenant usage metering: the "who is using what" half of the cost story.
# Every authenticated, tenant-scoped request increments an in-memory per-tenant
# counter; counts flush to the tenant_usage rollup so cost-to-serve is
# attributable per tenant (read back via GET /api/v1/usage). Per-tenant numbers
# live in Postgres, NOT Prometheus labels (5,000 tenants would explode the
# series count); only an aggregate counter reaches /metrics. In-memory and
# per-replica: each replica flushes its own deltas with an additive UPSERT, so
# replicas sum rather than overwrite. FLUSH_INTERVAL bounds both write volume
# and how stale the read endpoint is. Set ENABLED=false to turn it off.
ACCESS_USAGE_METERING_ENABLED=true
ACCESS_USAGE_METERING_FLUSH_INTERVAL=30s
# Tenant hibernation (scale-to-zero per tenant): the dormant-trial majority of a
# 5,000-tenant fleet should cost ~nothing in steady state. ztna-api records
# per-tenant activity and a reconcile sweep classifies tenants idle past
# DORMANT_IDLE as dormant; the periodic WORKERS then skip dormant tenants
# (connector identity syncs, scheduled review sweeps), and any real activity
# wakes a tenant on its next request. The gate is FAIL-OPEN: a never-classified
# tenant or any error always runs, so hibernation can only ever DEFER work for a
# confidently-dormant tenant, never drop it. When ENABLED=false the gate is a
# no-op (every tenant runs) everywhere — INCLUDING the workers — but activity is
# still recorded so the feature can be enabled later with accurate history.
ACCESS_TENANCY_HIBERNATION_ENABLED=true
# How long a tenant must go without recorded activity before it is classified
# dormant.
ACCESS_TENANCY_DORMANT_IDLE=336h
# How often the ztna-api reconcile sweep (re)classifies tenants set-based.
ACCESS_TENANCY_RECONCILE_INTERVAL=15m
# Write-coalescing window for request-path activity records (throttles duplicate
# records per tenant). Must stay far below DORMANT_IDLE.
ACCESS_TENANCY_ACTIVITY_FLUSH=60s
# Bound on the activity recorder's buffered enqueue channel (drops are safe: the
# reconcile sweep is the backstop classifier).
ACCESS_TENANCY_ACTIVITY_QUEUE_SIZE=8192
# Resource-budget tier for a tenant with no explicit override row.
ACCESS_TENANCY_DEFAULT_TIER=trial
# Listen address for the background WORKER binaries' minimal /metrics + /healthz
# server (access-connector-worker, access-workflow-engine). Those binaries serve
# no API of their own, but the aggregate hibernation skip counter increments
# inside them, so they must be scrapable for the saving to be observable.
# ztna-api ignores this (it serves /metrics on ACCESS_HTTP_ADDR). Set empty to
# disable the workers' metrics server.
# The default is shared by both workers: that is correct under the supported
# topologies (k8s runs each worker as its own Deployment/pod, docker-compose as
# its own container — each has its own network namespace, so :9090 never
# collides). Only if you co-locate both workers in ONE network namespace (e.g.
# two bare-metal binaries on a host) must you give each a distinct address, or
# the second to start logs a non-fatal bind error and its metrics go unscraped.
ACCESS_WORKER_METRICS_ADDR=:9090
